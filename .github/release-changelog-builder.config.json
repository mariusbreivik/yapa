{
  "template": "## Yapa #{{TO_TAG}}\n\n#{{CHANGELOG}}\n\n<details>\n<summary>Release stats</summary>\n\n- From: #{{FROM_TAG}}\n- To: #{{TO_TAG}}\n- Contributors: #{{CONTRIBUTORS}}\n- Diff: #{{RELEASE_DIFF}}\n\n</details>",
  "categories": [
    {
      "title": "### Added",
      "labels": ["feature", "enhancement"],
      "rules": [
        {
          "pattern": "^feat(\\(|:)",
          "on_property": "title"
        }
      ]
    },
    {
      "title": "### Fixed",
      "labels": ["fix", "bug", "bugfix"],
      "rules": [
        {
          "pattern": "^fix(\\(|:)",
          "on_property": "title"
        }
      ]
    },
    {
      "title": "### Changed",
      "labels": ["chore", "refactor", "maintenance"],
      "rules": [
        {
          "pattern": "^(chore|refactor)(\\(|:)",
          "on_property": "title"
        }
      ]
    },
    {
      "title": "### Docs",
      "labels": ["docs"],
      "rules": [
        {
          "pattern": "^docs(\\(|:)",
          "on_property": "title"
        }
      ]
    },
    {
      "title": "### Dependencies",
      "labels": ["dependencies", "deps"],
      "rules": [
        {
          "pattern": "^(deps|build|ci)(\\(|:)",
          "on_property": "title"
        }
      ]
    }
  ],
  "ignore_labels": ["skip-changelog"],
  "sort": {
    "order": "DESC",
    "on_property": "mergedAt"
  },
  "pr_template": "- #{{TITLE}} (#{{NUMBER}}) by @#{{AUTHOR}}",
  "empty_template": "- No changes"
}
